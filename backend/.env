# ============================================================
# AfriMarket Backend — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS COMMITER LE FICHIER .env
# ============================================================

# ── Serveur ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de données PostgreSQL ────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/afrimarket
# Ou séparément :
DB_HOST=localhost
DB_PORT=5432
DB_NAME=afrimarket
DB_USER=postgres
DB_PASS=votre_mot_de_passe
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=changez_ceci_avec_une_cle_aleatoire_de_64_chars_minimum
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=autre_cle_aleatoire_differente_de_la_precedente
JWT_REFRESH_EXPIRES_IN=30d

# ── Redis (sessions, OTP, cache) ──────────────────────────
REDIS_URL=redis://localhost:6379
# Ou Redis Cloud :
# REDIS_URL=redis://username:password@host:port

# ── Frontend URL (CORS) ───────────────────────────────────
FRONTEND_URL=http://localhost:5500,http://127.0.0.1:5500
# En production : FRONTEND_URL=https://www.afrimarket.com

# ── Twilio (SMS OTP) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Email (SendGrid) ──────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@afrimarket.com
EMAIL_FROM_NAME=AfriMarket

# ── Cloudinary (stockage images) ─────────────────────────
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=xxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# ── Orange Money API ─────────────────────────────────────
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay
ORANGE_MONEY_MERCHANT_KEY=xxxxxxxxxxxx
ORANGE_MONEY_MERCHANT_SECRET=xxxxxxxxxxxx

# ── Wave API ──────────────────────────────────────────────
WAVE_API_URL=https://api.wave.com/v1
WAVE_API_KEY=xxxxxxxxxxxx

# ── MTN Mobile Money ─────────────────────────────────────
MTN_MOMO_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=xxxxxxxxxxxx
MTN_MOMO_API_USER=xxxxxxxxxxxx
MTN_MOMO_API_KEY=xxxxxxxxxxxx

# ── Flutterwave (Visa/Mastercard) ────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxx

# ── Commission plateforme ─────────────────────────────────
PLATFORM_FEE_PERCENT=5

# ── Stockage KYC (dossiers identité — accès privé) ───────
KYC_STORAGE_BUCKET=afrimarket-kyc-private
KYC_ENCRYPTION_KEY=cle_32_bytes_pour_AES256_hex

# ── Admin ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@afrimarket.com
ADMIN_NOTIFICATION_WEBHOOK=https://...
